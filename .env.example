# ─────────────────────────────────────────────────────────────────────────────
#  Canadian Household Financial Data Bot — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Telegram Bot API token (from @BotFather on Telegram)
# How to get: https://core.telegram.org/bots/tutorial
BOT_TOKEN=your_telegram_bot_token_here

# Anthropic Claude API key (for AI summarisation)
# How to get: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# Logging verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# Set to "true" to run an immediate feed poll when the bot starts
# Useful for testing. Leave as "false" in production.
POLL_ON_STARTUP=false
